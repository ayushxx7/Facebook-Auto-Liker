# Facebook Auto-Liker CLI Demo
Output showcase/cli_power_demo.gif

Set Shell "bash"
Set FontSize 22
Set Width 1200
Set Height 600
Set Padding 40
Set Theme "Catppuccin Mocha"

Type "python3 autoLikeFB.py"
Sleep 500ms
Enter
Sleep 2s

# Show the bot waiting for the Facebook tab
Type "Waiting for Facebook button detection..."
Sleep 3s

# Simulate completion
Type "Successfully liked 5 images."
Sleep 1s
Enter
Sleep 2s
